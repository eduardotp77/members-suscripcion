        "html": "=<html><body style='font-family:Arial,sans-serif;background:#0a0a0a;color:#fff;padding:40px'><div style='max-width:700px;margin:0 auto;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:40px'><h1 style='color:#a855f7;margin-bottom:4px'>📋 Resumen Diario</h1><p style='color:rgba(255,255,255,0.4);margin-top:0'>{{ $json.fecha }}</p><p style='color:rgba(255,255,255,0.7)'>Hola <strong>{{ $json.ownerName }}</strong>, estos son tus clientes que vencen <strong style='color:#ef4444'>hoy</strong>:</p><div style='background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:12px;padding:16px 20px;margin:20px 0'><p style='margin:0;color:rgba(255,255,255,0.5);font-size:13px'>VENCEN HOY</p><p style='margin:4px 0 0;color:#ef4444;font-size:28px;font-weight:bold'>{{ $json.total }} cliente(s)</p></div><table style='width:100%;border-collapse:collapse'><thead><tr style='border-bottom:1px solid rgba(255,255,255,0.1)'><th style='padding:10px 12px;text-align:left;color:rgba(255,255,255,0.4);font-size:12px;font-weight:normal'>#</th><th style='padding:10px 12px;text-align:left;color:rgba(255,255,255,0.4);font-size:12px;font-weight:normal'>CLIENTE</th><th style='padding:10px 12px;text-align:left;color:rgba(255,255,255,0.4);font-size:12px;font-weight:normal'>PRODUCTO</th><th style='padding:10px 12px;text-align:left;color:rgba(255,255,255,0.4);font-size:12px;font-weight:normal'>VALOR</th><th style='padding:10px 12px;text-align:left;color:rgba(255,255,255,0.4);font-size:12px;font-weight:normal'>CORREO</th></tr></thead><tbody>{{ $json.listaHtml }}</tbody></table><p style='color:rgba(255,255,255,0.3);font-size:12px;margin-top:32px;text-align:center'>SociosMembres · Resumen automático diario</p></div></body></html>",
        "options": {
          "appendAttribution": false
        }
      },
