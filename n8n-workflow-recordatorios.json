    {
      "parameters": {
        "jsCode": "// Agrupar todos los items por user_id y construir resumen por dueño\nconst items = $input.all();\nif (!items || items.length === 0) return [];\n\nconst grupos = {};\nfor (const item of items) {\n  const c = item.json;\n  const uid = c.user_id;\n  const perfil = c.profiles || {};\n  if (!grupos[uid]) {\n    grupos[uid] = {\n      ownerEmail: perfil.email || '',\n      ownerName: perfil.nombre || 'Usuario',\n      clientes: []\n    };\n  }\n  grupos[uid].clientes.push(c);\n}\n\nconst fecha = new Date().toLocaleDateString('es-ES', {\n  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'\n});\n\nreturn Object.values(grupos)\n  .filter(g => g.ownerEmail)\n  .map(g => {\n    const listaHtml = g.clientes.map((c, i) => `\n      <tr style=\"border-bottom:1px solid rgba(255,255,255,0.05)\">\n        <td style=\"padding:12px;color:rgba(255,255,255,0.4);font-size:13px\">${i + 1}</td>\n        <td style=\"padding:12px;color:#fff;font-weight:bold\">${c.nombre}</td>\n        <td style=\"padding:12px;color:#a855f7\">${c.producto}</td>\n        <td style=\"padding:12px;color:#10b981\">$${c.valor_cobrado} USD</td>\n        <td style=\"padding:12px;color:rgba(255,255,255,0.6);font-size:13px\">${c.correo}</td>\n      </tr>`).join('');\n    return {\n      json: {\n        ownerEmail: g.ownerEmail,\n        ownerName: g.ownerName,\n        total: g.clientes.length,\n        listaHtml,\n        fecha\n      }\n    };\n  });"
      },
