    {
      "parameters": {
        "jsCode": "// Filtrar clientes cuya fecha_vencimiento sea en 3 días (lógica app)\n// CORREGIDO: La app usa differenceInDays que trunca fracciones de hora.\n// A las 8PM del día X, differenceInDays hasta el día X+4 devuelve 3.\n// Por eso buscamos fecha_vencimiento = hoy (Sao Paulo) + 4 días calendario.\n// Timezone: America/Sao_Paulo (UTC-3)\nconst OFFSET_SAO_PAULO = -3 * 60; // minutos\nconst ahora = new Date();\nconst localMs = ahora.getTime() + (OFFSET_SAO_PAULO - (-ahora.getTimezoneOffset())) * 60000;\nconst hoyLocal = new Date(localMs);\nhoyLocal.setDate(hoyLocal.getDate() + 4);\n\nconst año = hoyLocal.getFullYear();\nconst mes = String(hoyLocal.getMonth() + 1).padStart(2, '0');\nconst dia = String(hoyLocal.getDate()).padStart(2, '0');\nconst fechaBuscada = `${año}-${mes}-${dia}`;\n\nconst items = $input.all();\nconst filtrados = items.filter(item => item.json.fecha_vencimiento === fechaBuscada);\nif (filtrados.length === 0) return [];\nreturn filtrados;"
      },
      "id": "9144e978-f898-4bea-ac80-66307d40356e",
      "name": "Filtro: vencen EXACTAMENTE en 3 días",
