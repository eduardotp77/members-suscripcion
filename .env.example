# ══════════════════════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO - SOCIOSMEMBRES
# ══════════════════════════════════════════════════════════════════════════════
#
# IMPORTANTE: 
# - Renombra este archivo a .env antes de usarlo
# - NO subas el archivo .env a Git (ya está en .gitignore)
# - Estas son variables de BUILD-TIME (se embeben en el código compilado)
#
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE - Backend y Base de Datos
# ─────────────────────────────────────────────────────────────────────────────
#
# ¿Dónde obtener estos valores?
# 1. Ve a: https://supabase.com/dashboard
# 2. Selecciona tu proyecto
# 3. Ve a: Settings → API
# 4. Copia los valores correspondientes
#

# Project ID (Ref)
# Ubicación: Settings → General → Reference ID
VITE_SUPABASE_PROJECT_ID="Su_ID_Supabase"

# Anon/Public Key (clave pública)
# Ubicación: Settings → API → Project API keys → anon public
# Esta clave es segura para usar en el frontend
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."

# Project URL
# Ubicación: Settings → API → Project URL
# Formato: https://[tu-project-id].supabase.co
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# ══════════════════════════════════════════════════════════════════════════════
# NOTAS:
# ══════════════════════════════════════════════════════════════════════════════
#
# 1. NO uses el service_role key aquí (es secreto y solo para backend/servidor)
# 2. La anon key es pública y está protegida por Row Level Security (RLS)
# 3. Si cambias estas variables, debes rebuild: bun run build
# 4. En plataformas de deploy (Vercel, Netlify, etc.) agrega estas variables
#    en el dashboard de configuración
#
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# EXCHANGERATE-API - Tasas de Cambio de Monedas
# ─────────────────────────────────────────────────────────────────────────────
#
# ¿Dónde obtener esta API Key?
# 1. Ve a: https://www.exchangerate-api.com/
# 2. Regístrate con tu email (gratis, sin tarjeta)
# 3. Verifica tu email
# 4. Copia tu API Key desde el dashboard
#
# Plan Free:
# - 1,500 requests al mes (suficiente)
# - Actualización diaria de tasas
# - Soporte para 161 monedas
#
# Esta API se usa para convertir transacciones entre monedas (USD, BRL, COP, etc.)
#

VITE_EXCHANGE_RATE_API_KEY="your-api-key-here"

# ══════════════════════════════════════════════════════════════════════════════
